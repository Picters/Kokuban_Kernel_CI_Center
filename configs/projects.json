{
  "_globals": {
    "broadcast_channel": "@BLBDSBD",
    "resukisu_chat_id": "@ReSukiSU",
    "resukisu_topic_id": 36
  },
  "mi17_sm8850": {
    "repo": "Picters/android_kernel_xiaomi_sm8850-nethunter",
    "defconfig": "gki_defconfig",
    "localversion_base": "-android16-picters",
    "supported_ksu": [
      "resukisu"
    ],
    "version_method": "file",
    "toolchain_urls": [
      "https://github.com/cctv18/oneplus_sm8650_toolchain/releases/download/LLVM-Clang19-r536225/clang-r536225.zip",
      "https://github.com/cctv18/oneplus_sm8650_toolchain/releases/download/LLVM-Clang19-r536225/rust.zip",
      "https://github.com/cctv18/oneplus_sm8650_toolchain/releases/download/LLVM-Clang19-r536225/build-tools.zip",
      "https://github.com/rust-lang/rust-bindgen/releases/download/v0.69.5/bindgen-cli-x86_64-unknown-linux-gnu.tar.xz"
    ],
    "toolchain_path_prefix": "",
    "toolchain_path_exports": [
      "bin",
      "build-tools/bin",
      "bindgen-cli-x86_64-unknown-linux-gnu"
    ],
    "lto": "none",
    "anykernel_config": "canoe",
    "zip_name_prefix": "Mi17_Kernel",
    "nethunter_fragment": "nethunter.fragment",
    "nethunter_modules": "nethunter_modules.list",
    "nethunter_oot_modules": [
      {
        "repo": "https://github.com/aircrack-ng/rtl8812au.git",
        "subdir": "drivers/net/wireless/aircrack/rtl8812au",
        "make_args": ["CONFIG_88XXAU=m"]
      },
      {
        "repo": "https://github.com/aircrack-ng/rtl8188eus.git",
        "subdir": "drivers/net/wireless/aircrack/rtl8188eus",
        "make_args": ["CONFIG_RTL8188EU=m"]
      },
      {
        "repo": "https://github.com/morrownr/8814au.git",
        "subdir": "drivers/net/wireless/aircrack/rtl8814au",
        "make_args": ["CONFIG_RTL8814AU=m"]
      },
      {
        "repo": "https://github.com/morrownr/88x2bu-20210702.git",
        "subdir": "drivers/net/wireless/aircrack/88x2bu",
        "make_args": ["CONFIG_RTL8822BU=m"]
      }
    ],
    "susfs": {
      "repo": "https://gitlab.com/simonpunk/susfs4ksu.git",
      "branch": "gki-android16-6.12",
      "patch_path": "kernel_patches/50_add_susfs_in_gki-android16-6.12.patch",
      "fs_patch_dir": "kernel_patches/fs",
      "include_linux_patch_dir": "kernel_patches/include/linux"
    },
    "bbg": {
      "setup_url": "https://github.com/vc-teahouse/Baseband-guard/raw/main/setup.sh"
    },
    "readme_placeholders": {
      "DEVICE_NAME_CN": "小米 17 系列",
      "DEVICE_NAME_EN": "Xiaomi 17 Series"
    }
  }
}
